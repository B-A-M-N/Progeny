[gd_scene load_steps=2 format=3 uid="uid://onboarding_scene"]

[ext_resource type="Script" path="res://Onboarding.gd" id="1_onboard"]

[node name="Onboarding" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_onboard")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.07, 0.1, 0.12, 1)

[node name="Root" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 24.0
offset_top = 24.0
offset_right = -24.0
offset_bottom = -24.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 16

[node name="TopBar" type="HBoxContainer" parent="Root"]
layout_mode = 2

[node name="Title" type="Label" parent="Root/TopBar"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_font_sizes/font_size = 28
text = "Bitling First Meeting"

[node name="StatusLabel" type="Label" parent="Root/TopBar"]
layout_mode = 2
size_flags_horizontal = 3
horizontal_alignment = 2
text = "Connecting..."

[node name="TabContainer" type="TabContainer" parent="Root"]
layout_mode = 2
size_flags_vertical = 3

[node name="Parent" type="Control" parent="Root/TabContainer"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="ParentVBox" type="VBoxContainer" parent="Root/TabContainer/Parent"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 10

[node name="Intro" type="Label" parent="Root/TabContainer/Parent/ParentVBox"]
layout_mode = 2
autowrap_mode = 3
text = "Parent Baseline (Optional): help Bitling meet your child where they are."

[node name="WarmupTrack" type="HBoxContainer" parent="Root/TabContainer/Parent/ParentVBox"]
visible = false
layout_mode = 2
theme_override_constants/separation = 6

[node name="Dot1" type="ColorRect" parent="Root/TabContainer/Parent/ParentVBox/WarmupTrack"]
custom_minimum_size = Vector2(10, 10)
layout_mode = 2
color = Color(0.25, 0.28, 0.31, 1)

[node name="Dot2" type="ColorRect" parent="Root/TabContainer/Parent/ParentVBox/WarmupTrack"]
custom_minimum_size = Vector2(10, 10)
layout_mode = 2
color = Color(0.25, 0.28, 0.31, 1)

[node name="Dot3" type="ColorRect" parent="Root/TabContainer/Parent/ParentVBox/WarmupTrack"]
custom_minimum_size = Vector2(10, 10)
layout_mode = 2
color = Color(0.25, 0.28, 0.31, 1)

[node name="Grid" type="GridContainer" parent="Root/TabContainer/Parent/ParentVBox"]
layout_mode = 2
columns = 2
theme_override_constants/h_separation = 12
theme_override_constants/v_separation = 8

[node name="AgeLabel" type="Label" parent="Root/TabContainer/Parent/ParentVBox/Grid"]
layout_mode = 2
text = "Age"

[node name="AgeSpin" type="SpinBox" parent="Root/TabContainer/Parent/ParentVBox/Grid"]
layout_mode = 2
min_value = 2.0
max_value = 18.0
value = 6.0

[node name="CommLabel" type="Label" parent="Root/TabContainer/Parent/ParentVBox/Grid"]
layout_mode = 2
text = "Communication"

[node name="CommMode" type="OptionButton" parent="Root/TabContainer/Parent/ParentVBox/Grid"]
layout_mode = 2
item_count = 4
selected = 0
popup/item_0/text = "verbal"
popup/item_1/text = "partial verbal"
popup/item_2/text = "gestures"
popup/item_3/text = "aac/typing"

[node name="SoundLabel" type="Label" parent="Root/TabContainer/Parent/ParentVBox/Grid"]
layout_mode = 2
text = "Sound Sensitivity"

