[node name="Traits" type="HBoxContainer" parent="Root/TabContainer/Parent/ParentVBox"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="AutismLabel" type="Label" parent="Root/TabContainer/Parent/ParentVBox/Traits"]
layout_mode = 2
