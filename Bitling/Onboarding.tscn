[node name="OptionRow" type="HBoxContainer" parent="Root/TabContainer/Child/ChildVBox"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="OptionA" type="Button" parent="Root/TabContainer/Child/ChildVBox/OptionRow"]
layout_mode = 2
