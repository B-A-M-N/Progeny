[node name="ADHDLabel" type="Label" parent="Root/TabContainer/Parent/ParentVBox/Traits"]
layout_mode = 2
text = "ADHD Traits"

[node name="ADHDSlider" type="HSlider" parent="Root/TabContainer/Parent/ParentVBox/Traits"]
layout_mode = 2
size_flags_horizontal = 3
max_value = 1.0
step = 0.05
value = 0.5

[node name="NotesField" type="TextEdit" parent="Root/TabContainer/Parent/ParentVBox"]
custom_minimum_size = Vector2(0, 120)
layout_mode = 2
placeholder_text = "Notes: frustration cues, calming supports, school struggles..."

[node name="WarmupToggle" type="CheckBox" parent="Root/TabContainer/Parent/ParentVBox"]
layout_mode = 2
text = "Same child, warm-up runs (3 short sessions, increasingly engaging)"

[node name="ParentButtons" type="HBoxContainer" parent="Root/TabContainer/Parent/ParentVBox"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="SaveParentButton" type="Button" parent="Root/TabContainer/Parent/ParentVBox/ParentButtons"]
layout_mode = 2
