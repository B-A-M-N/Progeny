item_count = 3
selected = 1
popup/item_0/text = "low"
popup/item_1/text = "medium"
popup/item_2/text = "high"

[node name="LatencyLabel" type="Label" parent="Root/TabContainer/Parent/ParentVBox/Grid"]
layout_mode = 2
