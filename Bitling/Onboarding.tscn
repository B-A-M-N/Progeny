text = "Option B"

[node name="OptionC" type="Button" parent="Root/TabContainer/Child/ChildVBox/OptionRow"]
layout_mode = 2
size_flags_horizontal = 3
text = "Option C"

[node name="Hint" type="Label" parent="Root/TabContainer/Child/ChildVBox"]
