[node name="BeginChildButton" type="Button" parent="Root/TabContainer/Parent/ParentVBox/ParentButtons"]
layout_mode = 2
text = "Begin Child Session"

[node name="GoMainButton" type="Button" parent="Root/TabContainer/Parent/ParentVBox/ParentButtons"]
layout_mode = 2
text = "Skip To Companion"

[node name="Summary" type="RichTextLabel" parent="Root/TabContainer/Parent/ParentVBox"]
custom_minimum_size = Vector2(0, 160)
layout_mode = 2
bbcode_enabled = true
fit_content = false
text = "Summary will appear here after finishing child session."

[node name="Child" type="Control" parent="Root/TabContainer"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="ChildVBox" type="VBoxContainer" parent="Root/TabContainer/Child"]
